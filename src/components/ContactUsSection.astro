---
import { SITE } from '@consts';
---

<section id="contact" class="contact">
    <div class="section-container contact-container">
        <div class="contact-left">
            <span class="section-tag">KONTAKT</span>
            <h2 class="section-title">Porozmawiajmy o&nbsp;Twoim mieszkaniu</h2>
            <p class="contact-desc">Zostaw swoje dane — oddzwonimy i&nbsp;opowiemy, jak to wygląda w&nbsp;praktyce. Bez zobowiązań, bez presji.</p>

            <div class="contact-info">
                <div class="contact-info-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm3.445 17.827c-3.684 1.684-9.401-9.43-5.8-11.308l1.053-.519 1.746 3.409-1.042.513c-1.095.587 1.185 5.04 2.305 4.497l1.032-.505 1.76 3.397-1.054.516z"/></svg>
                    <a href="tel:+48510159125">510 159 125</a>
                </div>
            </div>
        </div>

        <form class="contact-form" action="">
            <div class="contact-form-fields">
                <div class="form-group">
                    <label class="form-label" for="name">Imię</label>
                    <input class="form-input" id="name" type="text" placeholder="Wpisz swoje imię" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="surname">Nazwisko</label>
                    <input class="form-input" id="surname" type="text" placeholder="Wpisz swoje nazwisko" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="email">E-mail</label>
                    <input class="form-input" id="email" type="email" placeholder="Wpisz swój e-mail" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="phone">Telefon</label>
                    <input class="form-input" id="phone" type="tel" placeholder="Wpisz swój numer telefonu" required />
                </div>
            </div>
            <div class="form-submit">
                <button type="submit" class="btn btn--primary btn--full">WYŚLIJ</button>
            </div>
            <div id="form-feedback" class="form-feedback" hidden>
                <p>Dziękujemy! Twoja wiadomość została wysłana.</p>
            </div>
        </form>
    </div>
</section>

<style>
    .contact {
        background-color: var(--color-white);
        padding-block: var(--px-96);
    }

    .contact-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--px-64);
        align-items: start;
    }

    .section-tag {
        display: inline-block;
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-accent);
        margin-bottom: var(--px-16);
    }

    .section-title {
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 700;
        color: var(--color-primary);
        margin-bottom: var(--px-24);
        letter-spacing: -0.01em;
    }

    .contact-desc {
        font-size: clamp(1.1rem, 1.5vw, 1.25rem);
        line-height: 1.7;
        color: var(--color-text-dark);
        margin-bottom: var(--px-40);
    }

    .contact-info {
        display: flex;
        flex-direction: column;
        gap: var(--px-12);
    }

    .contact-info-item {
        display: flex;
        align-items: center;
        gap: var(--px-10);
        font-size: var(--text-lg);
        font-weight: 500;
        color: var(--color-primary);
    }

    .contact-info-item svg {
        color: var(--color-accent);
        flex-shrink: 0;
    }

    .contact-info-item a {
        color: var(--color-primary);
        transition: color var(--transition-short);
    }

    .contact-form {
        background-color: var(--color-background);
        padding: var(--px-40);
        border-radius: var(--radius-md);
    }

    .contact-form-fields {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--px-20);
        margin-bottom: var(--px-28);
    }

    .form-group {
        display: grid;
        gap: var(--px-6);
    }

    .form-label {
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--color-primary);
    }

    .form-input {
        color: var(--color-text-primary);
        padding: var(--px-14) var(--px-16);
        border: 1px solid var(--color-border);
        background: var(--color-white);
        transition: all var(--transition-short);
        font-size: var(--text-sm);
        border-radius: var(--radius-sm);
    }

    .form-input:focus {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 2px rgba(45, 59, 45, 0.1);
        outline: none;
    }

    .btn--full {
        width: 100%;
        justify-content: center;
    }

    .form-feedback {
        margin-top: var(--px-16);
        color: var(--color-primary);
        font-weight: 500;
    }

    @media (hover: hover) and (pointer: fine) {
        .form-input:hover {
            border-color: var(--color-border-hover);
        }

        .contact-info-item a:hover {
            color: var(--color-accent);
        }
    }

    @media (max-width: 48rem) {
        .contact {
            padding-block: var(--px-64);
        }

        .contact-container {
            grid-template-columns: 1fr;
            gap: var(--px-40);
        }

        .contact-form-fields {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    document
        .querySelector('.contact-form')
        ?.addEventListener('submit', async e => {
            e.preventDefault();

            const form = e.target as HTMLFormElement;
            const feedback = document.getElementById('form-feedback');
            const submitButton = form.querySelector(
                'button[type="submit"]'
            ) as HTMLButtonElement;

            if (!feedback || !submitButton) return;

            submitButton.disabled = true;
            const originalText = submitButton.textContent;
            submitButton.textContent = 'WYSYŁANIE...';

            await new Promise(resolve => setTimeout(resolve, 1500));

            feedback.hidden = false;

            form.reset();
            submitButton.textContent = originalText;
            submitButton.disabled = false;

            setTimeout(() => {
                feedback.hidden = true;
            }, 4000);
        });
</script>
