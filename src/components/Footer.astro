---
import { SITE } from "@consts";

const currentYear = new Date().getFullYear();
---

<footer class="main-footer">
    <div class="section-container footer footer-primary">
        <div class="footer-brand">
            <a href="/" class="logo" aria-label="Stabilny Najem home">
                <img src="/logo-full.png" alt="Stabilny Najem" class="footer-logo-img" />
            </a>
            <p class="site-description">{SITE.DESCRIPTION}</p>

            <address class="footer-nav-list contact-info">
                <p class="phone">
                    <span class="label">T.</span>
                    <a href="tel:+48510159125">510 159 125</a>
                </p>
            </address>
        </div>

        <nav class="footer-navigation" aria-label="Footer navigation">
            <div class="footer-nav-section">
                <h2 class="headline footer-heading">Nawigacja</h2>
                <ul class="footer-nav-list">
                    <li>
                        <a href="#hero" class="footer-link">Strona główna</a>
                    </li>
                    <li>
                        <a href="#about" class="footer-link">O nas</a>
                    </li>
                    <li>
                        <a href="#how-it-works" class="footer-link">Jak to działa</a>
                    </li>
                    <li>
                        <a href="#contact" class="footer-link">Kontakt</a>
                    </li>
                </ul>
            </div>

            <div class="footer-nav-section">
                <h2 class="headline footer-heading">Prawne</h2>
                <ul class="footer-nav-list">
                    <li>
                        <a href="legal/privacy" class="footer-link">Polityka prywatności</a>
                    </li>
                    <li>
                        <a href="legal/terms" class="footer-link">Regulamin</a>
                    </li>
                </ul>
            </div>
        </nav>
    </div>

    <div class="footer footer-secondary">
        <div class="copyright">
            <p>&copy; {SITE.COMPANY_NAME} {currentYear}.</p>
        </div>
        <div class="location">
            <p>Kraków, Polska</p>
        </div>
    </div>
</footer>

<style>
    a {
        transition: all var(--transition-short);
    }

    a:active {
        color: var(--color-text-primary);
    }

    .main-footer {
        background-color: var(--color-primary);
        padding-block: var(--px-80) var(--px-28);
        padding-inline: var(--px-64);
        color: rgba(255, 255, 255, 0.7);
        font-size: var(--text-sm);
    }

    .footer {
        display: flex;
        justify-content: space-between;
    }

    .headline {
        color: var(--color-white);
    }

    .main-footer p {
        opacity: 1;
    }

    .footer-primary {
        margin-bottom: var(--px-80);
    }

    .footer-logo-img {
        height: 56px;
        width: auto;
        margin-bottom: var(--px-20);
    }

    .site-description {
        margin-bottom: var(--px-24);
        max-width: 20rem;
    }

    .footer-navigation {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        justify-content: space-between;
        width: 100%;
        margin-left: 16%;
        gap: var(--px-96);
    }

    .footer-heading {
        margin-bottom: var(--px-16);
        font-size: var(--text-lg);
        letter-spacing: -0.02em;
        font-weight: 500;
        text-wrap: nowrap;
    }

    .footer-nav-list {
        display: inline-flex;
        flex-direction: column;
        font-size: var(--text-sm);
        gap: var(--px-8);
        text-wrap: nowrap;
    }

    .footer-link {
        color: rgba(255, 255, 255, 0.7);
    }

    .contact-info {
        font-style: normal;
    }

    .contact-info a {
        color: rgba(255, 255, 255, 0.7);
    }

    .footer-secondary {
        font-weight: 500;
        color: rgba(255, 255, 255, 0.5);
    }

    @media (hover: hover) and (pointer: fine) {
        .footer-link:hover,
        .contact-info a:hover {
            color: var(--color-white);
        }
    }

    @media screen and (max-width: 64rem) {
        .main-footer {
            padding-top: var(--px-64);
            padding-inline: var(--px-28);
        }

        .footer {
            flex-wrap: wrap;
            gap: var(--px-48);
        }

        .footer-navigation {
            margin-left: 0;
            width: auto;
        }

        .footer-primary {
            margin-bottom: var(--px-64);
        }
    }

    @media screen and (max-width: 37.5rem) {
        .main-footer {
            padding-top: var(--px-48);
        }

        .footer-navigation {
            grid-template-columns: 1fr;
            width: 100%;
            gap: var(--px-28);
        }

        .footer-secondary {
            gap: var(--px-6) var(--px-48);
        }

        .footer-primary {
            margin-bottom: var(--px-48);
        }
    }
</style>
